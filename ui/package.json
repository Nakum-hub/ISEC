{
  "name": "isec-desktop-app",
  "version": "1.0.0",
  "description": "Internal Security Evidence Collector - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/run-electron.js",
    "build": "python ../scripts/release_build.py --ui-dir . --dist-dir dist --manifest ../build_manifest.json --skip-npm-ci",
    "build:manifest": "python ../scripts/create_build_manifest.py --dist-dir dist --output ../build_manifest.json --project-root .. --require-signed",
    "build:release": "python ../scripts/release_build.py --ui-dir . --dist-dir dist --manifest ../build_manifest.json --skip-npm-ci"
  },
  "keywords": [
    "cybersecurity",
    "forensics",
    "evidence",
    "collection",
    "security"
  ],
  "author": "ISEC Team",
  "license": "MIT",
  "build": {
    "appId": "com.isec.evidence.collector",
    "productName": "ISEC Evidence Collector",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../main.py",
        "to": "backend/main.py"
      },
      {
        "from": "../src",
        "to": "backend/src"
      },
      {
        "from": "../requirements.txt",
        "to": "backend/requirements.txt"
      },
      {
        "from": "../security_config.py",
        "to": "backend/security_config.py"
      },
      {
        "from": "../scripts",
        "to": "backend/scripts"
      },
      {
        "from": "../keys",
        "to": "keys",
        "filter": [
          "license_public_key.pem"
        ]
      }
    ],
    "files": [
      "**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": "${env.MAC_SIGN_IDENTITY}",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  }
}
