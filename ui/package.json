{
  "name": "isec-desktop-app",
  "productName": "ISEC",
  "version": "2.0.0",
  "description": "Internal Security Evidence Collector — Enterprise forensic evidence platform",
  "main": "main.js",
  "author": {
    "name": "ISEC Team"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "node scripts/run-electron.js",
    "build:win": "npm run build:backend && electron-builder --win",
    "build:mac": "npm run build:backend && electron-builder --mac",
    "build:linux": "npm run build:backend && electron-builder --linux",
    "build:backend": "cd .. && python build_backend.py",
    "postinstall": "electron-builder install-app-deps",
    "audit:check": "npm audit --audit-level=high"
  },
  "dependencies": {
    "electron-is-dev": "3.0.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "overrides": {
    "@xmldom/xmldom": ">=0.9.7",
    "ajv": ">=8.17.1",
    "brace-expansion": ">=2.0.2",
    "semver": ">=7.6.3",
    "ip": ">=2.0.1",
    "tough-cookie": ">=4.1.4",
    "nth-check": ">=2.1.1",
    "node-fetch": ">=2.7.0",
    "ws": ">=8.17.1"
  },
  "build": {
    "appId": "com.isec.evidencecollector",
    "productName": "ISEC",
    "copyright": "Copyright © 2026 ISEC Team",
    "asar": true,
    "asarUnpack": [
      "backend_dist/**/*",
      "keys/**/*"
    ],
    "extraResources": [
      {
        "from": "backend_dist",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../keys/license_public_key.pem",
        "to": "keys/license_public_key.pem"
      }
    ],
    "files": [
      "**/*",
      "!backend_dist/**",
      "!node_modules/.cache/**",
      "!**/*.map",
      "!**/*.ts"
    ],
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}],
      "icon": "assets/icon.ico",
      "publisherName": "ISEC",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ISEC Evidence Collector",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [{"target": "dmg", "arch": ["x64", "arm64"]}],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "ISEC Evidence Collector",
      "backgroundColor": "#020609"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
